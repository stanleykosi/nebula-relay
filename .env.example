# Nebula Relay environment example
# Copy to .env.local / .env and fill with development-only values.

# General
NODE_ENV=development
NEXT_PUBLIC_DEMO_MODE=fixture
NEXT_PUBLIC_PROOF_MODE=dev

# EVM
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
EVM_PRIVATE_KEY=
NEXT_PUBLIC_EVM_CHAIN_ID=11155111
NEXT_PUBLIC_EVM_ESCROW_ADDRESS=
NEXT_PUBLIC_EVM_MOCK_USDC_ADDRESS=

# Stellar
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_SOURCE_SECRET=
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_NEBULA_RELAY_CONTRACT_ID=
NEXT_PUBLIC_RISC0_VERIFIER_ROUTER_ID=
NEXT_PUBLIC_POOL_ADAPTER_CONTRACT_ID=
NEXT_PUBLIC_PRIVATE_PAYMENTS_POOL_ID=

# CCTP settlement proof of concept
CCTP_ENV=sandbox
CCTP_IRIS_API_URL=https://iris-api-sandbox.circle.com
CCTP_SOURCE_DOMAIN=
CCTP_TOKEN_MESSENGER_V2_ADDRESS=
CCTP_USDC_ADDRESS=
CCTP_MAX_FEE=0
CCTP_MIN_FINALITY_THRESHOLD=2000
CCTP_STELLAR_DOMAIN=27
CCTP_STELLAR_FORWARDER_ID=CA66Q2WFBND6V4UEB7RD4SAXSVIWMD6RA4X3U32ELVFGXV5PJK4T4VSZ
CCTP_STELLAR_MESSAGE_TRANSMITTER_ID=CBJ6MTCKKZG73PMDZCJMSFRD7DQEMI4FKDH7CGDSV4W6FHCRBCQAVVJY
CCTP_STELLAR_TOKEN_MESSENGER_MINTER_ID=CDNG7HXAPBWICI2E3AUBP3YZWZELJLYSB6F5CC7WLDTLTHVM74SLRTHP
NEXT_PUBLIC_CCTP_SETTLEMENT_MODE=poc

# Stage 13 scripts
NEBULA_ARTIFACT_DIR=artifacts/demo
NEBULA_RELAY_WASM=target/wasm32v1-none/release/nebula_relay_contract.wasm
NEBULA_ADMIN=
NEBULA_IMAGE_ID=0x4e4542554c415f4445565f494d4147455f49445f563100000000000000000000
NEBULA_NETWORK_DOMAIN=0x4e4542554c415f5354454c4c41525f544553544e45545f563100000000000000
NEBULA_WITNESS_FIXTURE=fixtures/valid-lock.json
NEBULA_PROOF_ARTIFACT=artifacts/dev-proof.json
NEBULA_DEMO_SUBMISSION=artifacts/demo/demo-submission.json
NEBULA_AUDITOR_PACKET=artifacts/demo/auditor-packet.json
NEBULA_LOCALNET_CONTRACTS=artifacts/demo/localnet-contracts.env
RISC0_VERIFIER_ROUTER_ID=
POOL_ADAPTER_CONTRACT_ID=
STELLAR_ASSET_CONTRACT_ID=
NEBULA_REGISTER_FIXTURE_CONFIG=1
RUN_LIVE=0

# RISC Zero
RISC0_DEV_MODE=1
RISC0_PROVER_MODE=dev
RISC0_IMAGE_ID=
BOUNDLESS_API_URL=
BOUNDLESS_API_KEY=

# Prover API
PROVER_API_URL=http://localhost:8787
PROVER_JOB_DIR=.nebula/prover-jobs

# Security
ALLOW_MOCK_VERIFIER=false
ALLOW_FIXTURE_WITNESS=true
