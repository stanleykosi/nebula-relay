RUN_LIVE=1

# RISC Zero
RISC0_DEV_MODE=0
RISC0_PROVER_MODE=remote
RISC0_IMAGE_ID=
BOUNDLESS_API_URL=
BOUNDLESS_API_KEY=

# Prover API
PROVER_API_URL=http://localhost:8787
PROVER_JOB_DIR=.nebula/prover-jobs

# Security
ALLOW_MOCK_VERIFIER=false
ALLOW_FIXTURE_WITNESS=false
