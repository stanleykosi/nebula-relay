# Nebula Relay environment template
# Keep this file free of real keys, API tokens, deployed contract IDs, and
# scanner-prone generated hashes. Put actual values in ignored .env.local or
# in Vercel/Railway environment variables.
# Do not put private keys in browser-facing NEXT_PUBLIC_* variables.

# General hosted testnet mode
NEXT_PUBLIC_DEMO_MODE=live
NEXT_PUBLIC_PROOF_MODE=remote
NEXT_PUBLIC_VERIFIER_MODE=real-router
NEXT_PUBLIC_CCTP_SETTLEMENT_MODE=testnet

# EVM
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
EVM_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
EVM_USER_PRIVATE_KEY=
NEBULA_EVM_OWNER=
NEXT_PUBLIC_EVM_NETWORK=sepolia
NEXT_PUBLIC_EVM_CHAIN_ID=11155111
NEXT_PUBLIC_EVM_ESCROW_ADDRESS=
NEXT_PUBLIC_EVM_MOCK_USDC_ADDRESS=
NEBULA_CCTP_ESCROW_ADDRESS=
NEXT_PUBLIC_NEBULA_CCTP_ESCROW_ADDRESS=

# Stellar
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE=
STELLAR_RPC_URL=
STELLAR_SOURCE_SECRET=
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_NEBULA_RELAY_CONTRACT_ID=
NEXT_PUBLIC_RISC0_VERIFIER_ROUTER_ID=
NEXT_PUBLIC_POOL_ADAPTER_CONTRACT_ID=
NEXT_PUBLIC_PRIVATE_PAYMENTS_POOL_ID=

# CCTP settlement proof of concept
CCTP_ENV=
CCTP_IRIS_API_URL=
CCTP_SOURCE_DOMAIN=
CCTP_TOKEN_MESSENGER_V2_ADDRESS=
CCTP_USDC_ADDRESS=
CCTP_MAX_FEE=
CCTP_MIN_FINALITY_THRESHOLD=
CCTP_STELLAR_DOMAIN=
CCTP_STELLAR_FORWARDER_ID=
CCTP_STELLAR_FORWARDER_BYTES32=
CCTP_STELLAR_FORWARDER_HOOK_DATA=
CCTP_STELLAR_MESSAGE_TRANSMITTER_ID=
CCTP_STELLAR_TOKEN_MESSENGER_MINTER_ID=

# Stage 13 scripts
NEBULA_ARTIFACT_DIR=artifacts/demo
NEBULA_RELAY_WASM=target/wasm32v1-none/release/nebula_relay_contract.wasm
NEBULA_ADMIN=
NEBULA_IMAGE_ID=
NEBULA_NETWORK_DOMAIN=
NEBULA_WITNESS_FIXTURE=fixtures/valid-lock.json
NEBULA_PROOF_ARTIFACT=artifacts/dev-proof.json
NEBULA_DEMO_SUBMISSION=artifacts/demo/demo-submission.json
NEBULA_AUDITOR_PACKET=artifacts/demo/auditor-packet.json
NEBULA_LOCALNET_CONTRACTS=artifacts/demo/localnet-contracts.env
NEBULA_MIN_AMOUNT=1000000
NEBULA_MAX_AMOUNT=500000000
NEBULA_LOCK_AMOUNT=100000000
NEBULA_NOTE_COMMITMENT=
NEBULA_COMPLIANCE_HINT=
RISC0_VERIFIER_ROUTER_ID=
POOL_ADAPTER_CONTRACT_ID=
STELLAR_ASSET_CONTRACT_ID=
NEBULA_REGISTER_FIXTURE_CONFIG=1
RUN_LIVE=1

# RISC Zero
RISC0_DEV_MODE=0
RISC0_PROVER_MODE=remote
RISC0_IMAGE_ID=
BOUNDLESS_API_URL=
BOUNDLESS_API_KEY=

# Prover API
PROVER_API_URL=
PROVER_JOB_DIR=.nebula/prover-jobs

# Security
ALLOW_MOCK_VERIFIER=false
ALLOW_FIXTURE_WITNESS=false
